#!/usr/bin/env bash

set -euo pipefail

MSG_FILE="$1"
REPO_ROOT="$(git rev-parse --show-toplevel)"
BRANCH="$(git rev-parse --abbrev-ref HEAD)"
CHANGELOG_FILE="$REPO_ROOT/_etc/_changelog.json"

# Solo su master
if [ "$BRANCH" != "master" ]; then
    exit 0
fi

mkdir -p "$(dirname "$CHANGELOG_FILE")"

# Rimuovo le righe commentate di Git
CLEAN_MSG="$(mktemp)"
sed '/^#/d' "$MSG_FILE" > "$CLEAN_MSG"

# Titolo = prima riga non vuota
TITOLO="$(awk 'NF { print; exit }' "$CLEAN_MSG" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"

# Testo = tutto dopo la prima riga non vuota
TESTO="$(
    awk '
        BEGIN { found=0 }
        {
            if (found == 0 && NF) {
                found=1
                next
            }
            if (found == 1) print
        }
    ' "$CLEAN_MSG" \
    | sed '1{/^[[:space:]]*$/d;}' \
    | sed ':a;/^[[:space:]]*$/{$d;N;ba;}' 2>/dev/null || true
)"

rm -f "$CLEAN_MSG"

# Fallback
if [ -z "${TITOLO:-}" ]; then
    TITOLO="Aggiornamento"
fi

TIMESTAMP="$(date -Iseconds)"

REMOTE_URL="$(git config --get remote.origin.url || true)"
REPO_URL=""

if [ -n "$REMOTE_URL" ]; then
    case "$REMOTE_URL" in
        git@github.com:*)
            REPO_URL="https://github.com/${REMOTE_URL#git@github.com:}"
            REPO_URL="${REPO_URL%.git}"
            ;;
        https://github.com/*)
            REPO_URL="${REMOTE_URL%.git}"
            ;;
        http://github.com/*)
            REPO_URL="${REMOTE_URL%.git}"
            ;;
        *)
            REPO_URL="$REMOTE_URL"
            ;;
    esac
fi

if [ -z "$REPO_URL" ]; then
    REPO_URL="https://github.com/"
fi

# Inizializza il file se manca
if [ ! -f "$CHANGELOG_FILE" ]; then
    echo "[]" > "$CHANGELOG_FILE"
fi

TMP_FILE="$(mktemp)"

jq \
  --arg titolo "$TITOLO" \
  --arg testo "$TESTO" \
  --arg timestamp "$TIMESTAMP" \
  --arg url "$REPO_URL" \
  '
  [
    {
      "titolo": $titolo,
      "testo": $testo,
      "timestamp": $timestamp,
      "url": $url
    }
  ] + .
  ' "$CHANGELOG_FILE" > "$TMP_FILE"

mv "$TMP_FILE" "$CHANGELOG_FILE"

git add -f "$CHANGELOG_FILE"

exit 0
