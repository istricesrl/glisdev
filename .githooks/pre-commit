#!/usr/bin/env bash

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
GIT_DIR="$(git rev-parse --git-dir)"
BRANCH="$(git rev-parse --abbrev-ref HEAD)"
CHANGELOG_FILE="$REPO_ROOT/_etc/_changelog.json"
COMMIT_MSG_FILE="$GIT_DIR/COMMIT_EDITMSG"

# Esegui solo su master
if [ "$BRANCH" != "master" ]; then
    exit 0
fi

# Recupera la prima riga utile del messaggio commit
RAW_MSG=""

if [ -f "$COMMIT_MSG_FILE" ]; then
    RAW_MSG="$(sed '/^#/d' "$COMMIT_MSG_FILE" | sed '/^[[:space:]]*$/d' | head -n 1 || true)"
fi

# Fallback
if [ -z "$RAW_MSG" ]; then
    RAW_MSG="Aggiornamento"
fi

# Parsing con separatore §
if [[ "$RAW_MSG" == *"§"* ]]; then
    TITOLO="${RAW_MSG%%§*}"
    TESTO="${RAW_MSG#*§}"
else
    TITOLO="$RAW_MSG"
    TESTO=""
fi

# Trim spazi
TITOLO="$(printf '%s' "$TITOLO" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
TESTO="$(printf '%s' "$TESTO" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"

# Timestamp ISO
TIMESTAMP="$(date -Iseconds)"

# URL repository remoto
REMOTE_URL="$(git config --get remote.origin.url || true)"
REPO_URL=""

if [ -n "$REMOTE_URL" ]; then
    case "$REMOTE_URL" in
        git@github.com:*)
            REPO_URL="https://github.com/${REMOTE_URL#git@github.com:}"
            REPO_URL="${REPO_URL%.git}"
            ;;
        https://github.com/*)
            REPO_URL="${REMOTE_URL%.git}"
            ;;
        http://github.com/*)
            REPO_URL="${REMOTE_URL%.git}"
            ;;
        *)
            REPO_URL="$REMOTE_URL"
            ;;
    esac
fi

if [ -z "$REPO_URL" ]; then
    REPO_URL="https://github.com/"
fi

# Crea cartella/file se non esistono
mkdir -p "$(dirname "$CHANGELOG_FILE")"

if [ ! -f "$CHANGELOG_FILE" ]; then
    echo "[]" > "$CHANGELOG_FILE"
fi

# Aggiorna JSON
TMP_FILE="$(mktemp)"

jq \
  --arg titolo "$TITOLO" \
  --arg testo "$TESTO" \
  --arg timestamp "$TIMESTAMP" \
  --arg url "$REPO_URL" \
  '
  [
    {
      "titolo": $titolo,
      "testo": $testo,
      "timestamp": $timestamp,
      "url": $url
    }
  ] + .
  ' "$CHANGELOG_FILE" > "$TMP_FILE"

mv "$TMP_FILE" "$CHANGELOG_FILE"

# Aggiungi il changelog allo staging
git add -f "$CHANGELOG_FILE"

exit 0
